{
  "name": "crow-central-agency",
  "version": "0.25.4",
  "description": "Multi-instance Claude Code manager with a bundled web UI for orchestrating multiple Claude Code agents from one place.",
  "homepage": "https://github.com/hmmroger/crow-central-agency#readme",
  "bugs": {
    "url": "https://github.com/hmmroger/crow-central-agency/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmmroger/crow-central-agency.git"
  },
  "license": "MIT",
  "author": "hmmroger",
  "keywords": [
    "crow",
    "agent",
    "claude",
    "claude-code",
    "claude-agent-sdk",
    "anthropic",
    "mcp",
    "model-context-protocol",
    "orchestration"
  ],
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "crow": "./dist/bin/crow.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/public/**",
    "!dist/**/*.map"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently -n shared,backend,frontend -c orange,blue,green \"npm run dev:shared\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:shared": "npm run dev -w packages/shared",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/shared && npm run lint && npm run build -w packages/backend && npm run build -w packages/frontend && npm run build:crow",
    "build:shared": "npm run build -w packages/shared",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:shared": "npm run lint -w packages/shared",
    "lint:backend": "npm run lint -w packages/backend",
    "lint:frontend": "npm run lint -w packages/frontend",
    "start": "cross-env NODE_ENV=production node dist/bin/crow.js",
    "build:crow": "tsc --project ./tsconfig.json && node scripts/rewrite-imports.mjs",
    "clean": "node ./scripts/clean-dist.mjs",
    "check:deps-sync": "node scripts/check-deps-sync.mjs",
    "bump-version": "node scripts/bump-version.mjs",
    "prepack": "npm run check:deps-sync && npm run clean -w @crow-central-agency/shared && npm run clean -w @crow-central-agency/backend && npm run clean && npm run build -w @crow-central-agency/shared && npm run lint && npm run build -w @crow-central-agency/backend && npm run build -w @crow-central-agency/frontend && npm run build:crow"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.76",
    "@anthropic-ai/sdk": "0.82.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/otel": "^0.18.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/instrumentation-undici": "^0.25.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "commander": "^14.0.3",
    "dompurify": "^3.4.1",
    "dotenv": "^17.3.1",
    "es-toolkit": "^1.46.0",
    "fast-xml-parser": "^5.7.1",
    "fastify": "^5.8.5",
    "jsdom": "^29.0.2",
    "mammoth": "^1.12.0",
    "node-html-markdown": "^2.0.0",
    "oceanic.js": "^1.14.0",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^24.12.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "mermaid": {
      "uuid": "^14.0.0"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
