# Server
HOST=localhost
PORT=3030

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5101

# Directory for Crow file-based storage (resolved from cwd)
CROW_SYSTEM_PATH=.crow

# Static file directory for serving frontend assets (optional, auto-detected from dist)
# STATIC_PATH=

# OpenAI-compatible API (e.g. llama.cpp) — generation features disabled if OPENAI_BASE_URL is not set
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=default

