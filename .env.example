# Server
HOST=localhost
PORT=3030

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5101

# Directory for Crow file-based storage (resolved from cwd)
CROW_SYSTEM_PATH=.crow

# Static file directory for serving frontend assets (optional, auto-detected from dist)
# STATIC_PATH=

# OpenAI or OpenAI-compatible API (e.g. llama.cpp) - generation features disabled if OPENAI_API_KEY is not set
# OPENAI_BASE_URL=
# OPENAI_API_KEY=None
# OPENAI_MODEL=default

