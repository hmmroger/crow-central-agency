# Access key for API and WebSocket authentication (required)
ACCESS_KEY=

# Server
# HOST defaults to localhost to keep the server bound to the loopback interface.
# For remote access, prefer a secure tunnel over changing HOST to 0.0.0.0 or a LAN/external interface.
HOST=localhost
PORT=3101

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5101

# Directory for Crow file-based storage.
# Defaults to ~/.crow (user home) when unset. Relative paths resolve from cwd;
# paths starting with ~ expand to the user's home directory.
# CROW_SYSTEM_PATH=

# Custom name for the Crow system agent (default: "Crow")
# CROW_SYSTEM_AGENT_NAME=Crow

# Static file directory for serving frontend assets (optional, auto-detected from dist)
# STATIC_PATH=

# Number of days to retain closed tasks before pruning on startup (default: 30)
# CLOSED_TASK_RETENTION_DAYS=30

# OpenAI-compatible chat completion API - persona / agent MD generation features not available if not set
# Provider can be: ANTHROPIC, GOOGLE, OPENAI, CUSTOM
# TEXT_GENERATION_PROVIDER=CUSTOM
# TEXT_GENERATION_API_KEY=
# Base URL only required for CUSTOM provider; known providers use their default endpoints
# TEXT_GENERATION_BASE_URL=http://localhost:8080/v1
# TEXT_GENERATION_MODEL=default

# Used by the feed manager to summarize feed item content. Optional, but recommended:
# summaries normalize feed items to a consistent length, giving agents a more uniform
# and higher-quality signal when consuming feeds. Same provider options as above.
# FEED_TEXT_GENERATION_PROVIDER=
# FEED_TEXT_GENERATION_API_KEY=
# FEED_TEXT_GENERATION_BASE_URL=
# FEED_TEXT_GENERATION_MODEL=

# OpenTelemetry (disabled by default)
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=crow-central-agency
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
